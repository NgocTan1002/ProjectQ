# =============================================================================
# ProjectQ — Environment Variables Template
# Copy file này thành .env rồi điền giá trị thực.
# File này ĐƯỢC commit lên git (không chứa secrets thật).
# =============================================================================

# --- Django Core ---
SECRET_KEY=your-very-long-and-random-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (PostgreSQL) ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=projectq_db
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# --- Cache / Celery (Redis) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Email ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_email_password
DEFAULT_FROM_EMAIL=noreply@projectq.vn

# --- Django Environment ---
# Giá trị hợp lệ: dev | prod
DJANGO_SETTINGS_MODULE=config.settings.dev

# --- Media / Static (prod dùng S3) ---
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-southeast-1

# --- Company info (inject vào mọi template qua context processor) ---
COMPANY_NAME=Tên công ty của bạn
COMPANY_ADDRESS=Địa chỉ công ty, Quận, TP.HCM
COMPANY_PHONE=0901234567
COMPANY_EMAIL=contact@example.com

# --- Sentry (prod) ---
SENTRY_DSN=
